# Flask API server
# Defaults shown are for local development.

# Host/port for the Flask API (0.0.0.0 for production, 127.0.0.1 for local)
API_HOST=0.0.0.0
PORT=5000

# Comma-separated list of allowed CORS origins.
# Local dev default: http://localhost:3000,http://localhost:3001
# Production example: https://axiompicks.com,https://www.axiompicks.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
